# ===========================================
# CXSAMAA — Local Development Environment
# ===========================================
# Copy to .env.local and fill in real values:
#   cp .env.example .env.local
# ===========================================

# --- Database ---
# Neon (recommended): https://console.neon.tech
# Or use Docker Postgres via docker-compose
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname
DATABASE_URL_SYNC=postgresql://user:password@host:5432/dbname?sslmode=require

# --- Redis ---
# Local: redis://localhost:6379/0
# Upstash: https://console.upstash.io
REDIS_URL=redis://localhost:6379/0
# UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# --- JWT Authentication ---
JWT_SECRET=change-me-to-a-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# --- File Storage ---
# Options: local, r2
STORAGE_BACKEND=local
# LOCAL_UPLOAD_DIR=./uploads

# --- Cloudflare R2 (when STORAGE_BACKEND=r2) ---
# Get from: https://dash.cloudflare.com → R2
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=

# --- NVIDIA NIM API ---
# Used for: embeddings, optional STT/diarization
# Get from: https://build.nvidia.com
# NVIDIA_API_KEY=nvapi-your-key
# NVIDIA_STT_MODEL=parakeet-rnnt-1.1b
# NVIDIA_DIARIZATION_MODEL=streusand-rnnt
# NVIDIA_LLM_MODEL=meta/llama-3.3-70b-instruct

# --- STT Provider ---
# Options: deepgram, groq, riva
STT_PROVIDER=deepgram

# --- STT Fallback ---
# Used when primary STT fails or times out
# STT_FALLBACK_PROVIDER=deepgram
# DEEPGRAM_API_KEY=your-deepgram-key
# DEEPGRAM_STT_MODEL=nova-3

# --- LLM Provider ---
# Options: deepseek, nvidia
LLM_PROVIDER=deepseek

# --- DeepSeek (V4 LLM) ---
# Get from: https://platform.deepseek.com/api_keys
# DEEPSEEK_API_KEY=your-deepseek-key
# DEEPSEEK_LLM_MODEL=deepseek-v4-flash

# --- Pyannote.audio (Local Diarization) ---
# Optional — uses ~300MB RAM. Disable on low-memory machines.
# Get token: https://hf.co/settings/tokens
# DIARIZATION_USE_PYANNOTE=false
# PYANNOTE_HF_TOKEN=your-huggingface-token
# PYANNOTE_MODEL_NAME=pyannote/speaker-diarization-3.1

# --- Application ---
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# --- CORS ---
CORS_ORIGINS=http://localhost:3000

# ===========================================
# Frontend (apps/web) — set via turbo.json env
# ===========================================
# NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
