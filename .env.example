# ===========================================
# SAMAA Environment Variables
# Copy this file to .env and fill in the values
# ===========================================

# --- Database ---
# Local Development (Docker PostgreSQL):
#   DATABASE_URL=postgresql+asyncpg://samaa:samaa_dev_password@localhost:5432/samaa
#   DATABASE_URL_SYNC=postgresql://samaa:samaa_dev_password@localhost:5432/samaa
#
# Production (Neon PostgreSQL):
#   DATABASE_URL=postgresql+asyncpg://user:password@host/dbname?sslmode=require
#   DATABASE_URL_SYNC=postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql+asyncpg://samaa:samaa_dev_password@localhost:5432/samaa
DATABASE_URL_SYNC=postgresql://samaa:samaa_dev_password@localhost:5432/samaa

# --- Redis ---
# Local Development (Docker Redis):
#   REDIS_URL=redis://localhost:6379/0
#
# Production (Upstash Redis):
#   REDIS_URL=rediss://default:password@host:port
#   UPSTASH_REDIS_REST_URL=https://your-org.upstash.io
#   UPSTASH_REDIS_REST_TOKEN=your-token
REDIS_URL=redis://localhost:6379/0

# --- JWT Authentication ---
JWT_SECRET=change-me-to-a-random-secret-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- File Storage ---
# Options: local, r2
STORAGE_BACKEND=local
LOCAL_UPLOAD_DIR=./uploads

# --- Cloudflare R2 (when STORAGE_BACKEND=r2) ---
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=samaa-audio
# R2_PUBLIC_URL=  # Set if bucket has public access enabled (e.g., https://pub-xxx.r2.dev)

# --- NVIDIA NIM API ---
# Used for: embeddings, diarization (cloud), optional LLM fallback
NVIDIA_API_KEY=
NVIDIA_STT_MODEL=parakeet-rnnt-1.1b
NVIDIA_DIARIZATION_MODEL=streusand-rnnt
NVIDIA_LLM_MODEL=meta/llama-3.3-70b-instruct

# --- STT Provider ---
# Primary STT provider:
#   "riva" = NVIDIA Riva Parakeet via gRPC (requires riva-client)
# Fallback STT provider (automatic when primary fails):
#   "deepgram" = Deepgram Nova (high accuracy, REST API)
STT_PROVIDER=riva
STT_FALLBACK_PROVIDER=deepgram

# --- Deepgram STT (Fallback Provider) ---
# Get key from: https://console.deepgram.com
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-3  # Deepgram STT model (nova-3, nova-2, etc.)
DEEPGRAM_LANGUAGE=en  # Language code (en, hi, ar, multilingual)


# --- LLM Provider ---
# Primary LLM provider:
#   "deepseek" = DeepSeek V4 (fast, cheap, OpenAI-compatible)
#   "nvidia"   = NVIDIA NIM (Llama 3.3 70B)
# Fallback LLM provider (automatic when primary fails):
#   "nvidia"   = NVIDIA NIM (Llama 3.3 70B) — fallback when DeepSeek fails
#   "deepseek" = DeepSeek V4 — fallback when NVIDIA fails
LLM_PROVIDER=deepseek
LLM_FALLBACK_PROVIDER=nvidia

# --- DeepSeek (V4 LLM) ---
# Get key from: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=
DEEPSEEK_LLM_MODEL=deepseek-v4-flash  # or "deepseek-v4-pro" for higher quality

# --- Pyannote.audio (Local Diarization) ---
# Get token from: https://hf.co/settings/tokens
# Pyannote provides superior diarization accuracy vs cloud APIs

# Enable/Disable Diarization Stage
# Set to 'false' to skip speaker diarization entirely (faster processing, no speaker labels)
# Useful when you only need transcription analysis without speaker identification
ENABLE_DIARIZATION=true
DIARIZATION_USE_PYANNOTE=true
PYANNOTE_HF_TOKEN=
PYANNOTE_MODEL_NAME=pyannote/speaker-diarization-3.1
# PYANNOTE_DEVICE=  # 'cpu', 'cuda', 'mps' (leave empty for auto-detect)

# --- Silero VAD (Voice Activity Detection) ---
# Detects speech regions to remove silence and reduce processing costs
VAD_USE_SILERO=true
VAD_THRESHOLD=0.5  # Speech probability threshold (0.0-1.0)
VAD_MIN_SPEECH_DURATION_MS=250  # Minimum speech segment duration
VAD_MIN_SILENCE_DURATION_MS=500  # Minimum silence to mark boundary

# --- Audio Chunking for Long Recordings ---
# Process long audio in chunks with overlap to maintain context
# 10 min of 16 kHz mono WAV ≈ 19.2 MB (well under typical API limits)
AUDIO_CHUNK_DURATION_MINUTES=10  # 10-minute chunks (~19 MB per chunk at 16 kHz mono)
AUDIO_CHUNK_OVERLAP_SECONDS=30  # 30-second overlap between chunks

# --- Conversation Turn Builder ---
# Merges word-level transcripts into speaker turns
TURN_GAP_THRESHOLD=1.0  # Max seconds between words to continue turn

# --- Role Classification ---
# Classifies speakers as Salesperson or Customer
ROLE_CLASSIFICATION_METHOD=LLM  # LLM or Heuristic (LLM tries first, falls back to Heuristic)
ROLE_CLASSIFICATION_CONFIDENCE_THRESHOLD=0.7  # Min confidence to trust LLM result

# --- Application ---
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# --- CORS ---
CORS_ORIGINS=http://localhost:3000
